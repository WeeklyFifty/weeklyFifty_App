# Weekly Fifty — environment variables
#
# Copy this file to `.env` and fill in the values. `.env` is gitignored.
#
# Anything prefixed EXPO_PUBLIC_ is bundled into the JS runtime and readable
# by the app at runtime. Anything else is build-time only (read by app.config.ts
# or EAS).
#
# Sources:
#   - RevenueCat keys:         https://app.revenuecat.com → Project → Apps → Public App-specific API keys
#   - PostHog key:             https://app.posthog.com → Project Settings → Project API Key
#   - Sentry DSN:              https://sentry.io → Settings → Projects → Client Keys (DSN)
#   - Google OAuth client id:  https://console.cloud.google.com → APIs & Services → Credentials (Web application client)
#   - Apple/EAS project id:    created by `eas init` — populated automatically in app.config.ts

# --- Public (EXPO_PUBLIC_*) — bundled into JS, safe to expose to clients ---

EXPO_PUBLIC_API_BASE_URL=https://api.theweeklyfifty.com.au
EXPO_PUBLIC_SENTRY_DSN=https://example@sentry.io/000000
EXPO_PUBLIC_POSTHOG_KEY=phc_REPLACE_ME
EXPO_PUBLIC_RC_KEY_IOS=appl_REPLACE_ME
EXPO_PUBLIC_RC_KEY_ANDROID=goog_REPLACE_ME
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=000000-REPLACE_ME.apps.googleusercontent.com

# --- Build-time only ---

# Selects which bundle id / API URL / config to use.
# Allowed: development | staging | production
APP_ENV=development

# Created by `eas init`. Leave blank before first `eas init`.
EAS_PROJECT_ID=
